            :<Inp lbl="Invite Code" ph="e.g. a1b2c3d4" val={form.code} onChange={f("code")}/>}
          <Sel lbl="Your Role" val={form.role} onChange={f("role")} opts={mode==="new"?[{v:"ceo",l:"CEO / Founder"}]:[{v:"mgr",l:"Engineering Manager"},{v:"dev",l:"Developer"}]}/>
          {mode==="join"&&<div style={{fontSize:11,color:C.txt3}}>Invite code taro Manager/CEO pase thi malshe (Settings ma dikhay che)</div>}
