function AutoRiskDetection({projs,token,uid,companyId,onRiskAdded}){
  const[detected,sD]=useState([]);const[loading,sL]=useState(false);
  
  const detect = async () => {
    sL(true);
    const riskyProjects = projs.filter(p => (p.health_score||0) < 50);
    const newRisks = [];
    for(const p of riskyProjects){
      newRisks.push({
        description: `⚠️ Auto-detected: Project "${p.name}" has low health (${p.health_score}%)`,
        severity: p.health_score < 30 ? 'critical' : 'high',
        financial_impact: 'TBD',
        owner_name: p.team || 'Unassigned',
        project_id: p.id,
        company_id: companyId
      });
    }
    // Auto-add risks
    for(const risk of newRisks){
      await api.addRisk(token, uid, risk);
    }
    sD(newRisks);
    sL(false);
    if(newRisks.length) onRiskAdded();
  };
  
  return<Card sx={{border:`1px solid ${C.red}30`}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
      <div style={{fontSize:13,fontWeight:700,color:C.red}}>⚠️ Auto Risk Detection</div>
      <Btn v="red" sz="sm" onClick={detect} dis={loading}>{loading?<Spin/>:"Scan"}</Btn>
    </div>
    {detected.length>0?detected.map((r,i)=><div key={i} style={{padding:"6px 10px",background:`${C.red}15`,borderRadius:4,marginBottom:4,fontSize:12,color:C.red}}>• {r.description}</div>):
      <div style={{color:C.txt2,fontSize:12}}>Click Scan to auto-detect risks in projects with low health</div>
    }
  </Card>;
}

