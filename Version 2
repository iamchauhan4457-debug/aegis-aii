// ============================================================
// MAIN APP
// ============================================================
function App(){
  const[sc,sSc]=useState("login");const[auth,sAuth]=useState(null);const[prof,sProf]=useState(null);const[pg,sPg]=useState("dash");const[projId,sProjId]=useState(null);
  const[recoveryToken,sRecTok]=useState(null);const[booting,sBooting]=useState(true);
  
  useEffect(()=>{
    const hash=window.location.hash;
    if(hash&&hash.includes("type=recovery")){
      const params=new URLSearchParams(hash.substring(1));
      const tok=params.get("access_token");
      if(tok){sRecTok(tok);sSc("reset");window.history.replaceState(null,"",window.location.pathname);sBooting(false);return;}
    }
    const saved=session.load();
    if(saved&&saved.access_token&&saved.user){
      api.prof(saved.access_token,saved.user.id).then(p=>{
        sAuth(saved);
        sProf(p||{full_name:saved.user.email?.split("@")[0],role:"mgr"});
        sSc("app");sBooting(false);
      }).catch(()=>{session.clear();sBooting(false);});
    }else{
      sBooting(false);
    }
  },[]);
  
  const login=async(data)=>{sAuth(data);session.save(data);const p=await api.prof(data.access_token,data.user.id);sProf(p||{full_name:data.user.email?.split("@")[0],role:"mgr"});sSc("app");sPg("dash");};
  const logout=async()=>{if(auth)await api.out(auth.access_token);session.clear();sAuth(null);sProf(null);sSc("login");};
  const nav=(p,id)=>{if(p==="price"){sSc("price");return;}if(p==="project_detail" && id){sPg("project_detail");sProjId(id);return;}sPg(p);sProjId(null);};
  const ssoLogin=(provider)=>{window.location.href=`${SB}/auth/v1/authorize?provider=${provider}&redirect_to=${window.location.origin}`;};
  
  const page=()=>{
    if(!auth)return null;
    const role=prof?.role||"mgr";
    const companyId=prof?.company_id;
    const [projs,sP]=useState([]);
    const [risks,sR]=useState([]);
    const [loading,sL]=useState(true);
    
    useEffect(()=>{
      if(!companyId){sL(false);return;}
      Promise.all([api.projs(auth.access_token,companyId),api.risks(auth.access_token,companyId)]).then(([p,r])=>{
        sP(Array.isArray(p)?p:[]);
        sR(Array.isArray(r)?r:[]);
        sL(false);
      });
    },[companyId,auth.access_token]);
    
    switch(pg){
      case"dash":return<Dashboard user={auth.user} prof={prof} token={auth.access_token} onNav={nav}/>;
      case"analytics":return<AnalyticsDashboard token={auth.access_token} companyId={companyId} projs={projs} risks={risks}/>;
      case"proj":return<Projects token={auth.access_token} uid={auth.user.id} role={role} companyId={companyId} onNav={nav}/>;
      case"risks":return<Risks token={auth.access_token} uid={auth.user.id} role={role} companyId={companyId}/>;
      case"team":return<TeamPage token={auth.access_token} companyId={companyId} uid={auth.user.id} role={role}/>;
      case"chat":return<ChatPage token={auth.access_token} companyId={companyId} uid={auth.user.id} projs={projs}/>;
      case"audit":return<AuditLog token={auth.access_token} companyId={companyId}/>;
      case"summary":return<WeeklySummary token={auth.access_token} prof={prof} companyId={companyId}/>;
      case"privacy":return<PrivacyTerms page="privacy" onBack={()=>sPg("dash")}/>;
      case"terms":return<PrivacyTerms page="terms" onBack={()=>sPg("dash")}/>;
      case"cfg":return<Settings token={auth.access_token} uid={auth.user.id} prof={prof} onUpdate={p=>sProf({...prof,...p})} onNav={nav} companyId={companyId}/>;
      case"project_detail":return<ProjectDetail projId={projId} token={auth.access_token} companyId={companyId} onBack={()=>sPg("proj")} uid={auth.user.id}/>;
      default:return<Dashboard user={auth.user} prof={prof} token={auth.access_token} onNav={nav}/>;
    }
  };
  
  if(booting)return<div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:C.bg}}><Spin/></div>;
  
  return<div style={{fontFamily:"Inter,-apple-system,sans-serif",background:C.bg,minHeight:"100vh",color:C.txt}}>
    {sc==="login"&&<Login onLogin={login} onSignup={()=>sSc("signup")} onForgot={()=>sSc("forgot")} onSSO={ssoLogin}/>}
    {sc==="signup"&&<Signup onLogin={login}/>}
    {sc==="forgot"&&<ForgotPw onBack={()=>sSc("login")}/>}
    {sc==="reset"&&<ResetPw token={recoveryToken} onDone={()=>sSc("login")}/>}
    {sc==="price"&&<Pricing onBack={()=>sSc("app")}/>}
    {sc==="app"&&<div style={{display:"flex",minHeight:"100vh"}}>
      <Sidebar user={auth?.user} prof={prof} pg={pg} onNav={nav} onOut={logout}/>
      <div style={{flex:1,display:"flex",flexDirection:"column",minWidth:0}}>
        <header style={{height:52,background:C.surf,borderBottom:`1px solid ${C.border}`,display:"flex",alignItems:"center",justifyContent:"space-between",padding:"0 20px",fontSize:14,fontWeight:700,position:"sticky",top:0,zIndex:10}}>
          <span>{TT[pg]||"Dashboard"}</span>
          <div style={{display:"flex",gap:8}}>
            <PWAInstall/>
          </div>
        </header>
        <main style={{flex:1,padding:20,overflowY:"auto"}}>{page()}</main>
      </div>
    </div>}
  </div>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
