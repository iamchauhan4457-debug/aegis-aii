function AIInsights({projs, risks, onNav, uid, plan, role}){
  const[text,sText]=useState("");
  const[structured,sStructured]=useState(null);
  const[loading,sL]=useState(false);
  const[err,sErr]=useState("");
  const[confidence,sConf]=useState(0);
  const[feedback,sFB]=useState(null);
  
  const activePlan=plan||"trial";
  const limit=usageCap.limit(activePlan);
  const used=uid?usageCap.get(uid):0;
  const remaining=Math.max(0, limit-used);

  const buildPrompt=(inputData,userRole)=>{
    const base=`Projects: ${inputData.totalProjects}, Health: ${inputData.healthScore}%, Critical Risks: ${inputData.criticalRisks}, Financial Exposure: ₹${inputData.financialExposure}`;
    let roleContext="";
    if(userRole==="ceo") roleContext="CEO Mind: Focus on ROI, Investment, Timeline, Business Decisions.";
    else if(userRole==="mgr") roleContext="Manager Mind: Focus on Team Size, Sprint Velocity, Capacity, Burnout Risks.";
    else if(userRole==="dev") roleContext="Developer Mind: Focus on Technical Debt, Architecture Risks, Code Quality.";
    else roleContext="General Analyst.";
    return `You are a senior ${userRole||"tech"} advisor. ${roleContext} Data: ${base}. 
Projects Raw: ${JSON.stringify(inputData.projectDetails.slice(0,5))}. 
Risks Raw: ${JSON.stringify(inputData.riskDetails.slice(0,5))}.

INSTRUCTIONS: Return ONLY valid JSON (no markdown). Follow this exact schema:
{
  "data_used": {
    "projects_count": "X projects analyzed",
    "avg_health": "XX%",
    "critical_risks": "X critical",
    "total_financial": "₹X",
    "quality": "High/Medium/Low"
  },
  "verification": {
    "cross_check": "Mathematical verification e.g., (Health ${inputData.healthScore}% + Risk ${inputData.riskScore}/100) = Medium-High",
    "warnings": ["Warning if data<3 projects or missing owners", "or null if none"],
    "sufficiency": "Sufficient/Insufficient"
  },
  "reasoning": [
    "Step 1: Project health is X%, which means...",
    "Step 2: Due to Y critical risks, the team will face Z delays.",
    "Step 3: Therefore, the investment/timeline/team must adjust."
  ],
  "advice": "Single, actionable line of advice (max 20 words).",
  "confidence": 85
}

IMPORTANT RULES:
- If totalProjects < 2, set "quality": "Low", "sufficiency": "Insufficient", and confidence < 50.
- If criticalRisks > 2, add a specific warning about "financial or timeline impact".
- The "reasoning" array must have exactly 3 clear steps.
- The "advice" must be specific to the ${userRole} role.`;
  };

  const gen=async()=>{
    const key=gemKey.get();
    if(!key){sErr("⚠️ Settings ma Gemini API key nakho (aistudio.google.com/apikey thi free key lai ne save karo).");return;}
    if(uid && used>=limit){sErr(`⚠️ Limit puri (${activePlan}). Upgrade karo ya kal try karo.`);return;}
    sL(true);sErr("");sText("");sStructured(null);sConf(0);sFB(null);
    try{
      const totalHealth=projs.length>0?Math.round(projs.reduce((a,p)=>a+(p.health_score||75),0)/projs.length):0;
      const totalRisk=risks.length>0?Math.round(risks.reduce((a,r)=>a+(r.severity==="critical"?30:r.severity==="high"?20:10),0)/risks.length):0;
      const criticalRisks=risks.filter(r=>r.severity==="critical").length;
      const financialTotal=risks.reduce((a,r)=>a+(parseInt(r.financial_impact)||0),0);
      const inputData={
        totalProjects:projs.length,
        healthScore:totalHealth,
        riskScore:totalRisk,
        criticalRisks:criticalRisks,
        financialExposure:financialTotal,
        projectDetails:projs.map(p=>({name:p.name,status:p.status,health:p.health_score,team:p.team})),
        riskDetails:risks.map(r=>({desc:r.description,severity:r.severity,impact:r.financial_impact}))
      };
      const prompt=buildPrompt(inputData,role||"mgr");
      const res=await askGemini(key,prompt);
      sL(false);
      if(res.error){sErr("AI Error: "+res.message);return;}
      if(!res.text){sErr("No response from AI");return;}
      let clean=res.text.replace(/```json/g,'').replace(/```/g,'').trim();
      let parsed;
      try{parsed=JSON.parse(clean);}catch(e){
        sErr("AI returned invalid JSON. Raw: "+res.text.slice(0,150)+"...");
        return;
      }
      if(!parsed.data_used || !parsed.verification || !parsed.reasoning || !parsed.advice){
        sErr("AI JSON missing required keys.");
        return;
      }
      const conf=Math.min(100,Math.max(0,parsed.confidence||70));
      sConf(conf);
      sStructured(parsed);
      sText(JSON.stringify(parsed,null,2));
      if(uid) usageCap.inc(uid);
    }catch(ex){sL(false);sErr("Error: "+(ex?.message||String(ex)));}
  };

  const roleTitle={ceo:"🧠 CEO Strategy",mgr:"🧠 Manager Insights",dev:"🧠 Technical Analysis"}[role]||"🧠 AI Analysis";
  return(
    <Card sx={{marginTop:14,border:`1px solid ${C.cyan}30`}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
        <div style={{fontSize:13,fontWeight:700}}>✨ {roleTitle}</div>
        <Btn v="out" sz="sm" onClick={gen} dis={loading||remaining<=0}>
          {loading?<Spin/>:"⚡ Generate"}
        </Btn>
      </div>
      <div style={{fontSize:10,color:C.txt3,marginBottom:10}}>Credits: {remaining}/{limit} ({activePlan})</div>
      {!structured&&!loading&&!err&&(
        <div style={{fontSize:12,color:C.txt2,padding:"4px 0"}}>
          {role==="ceo"&&"💼 ROI, Investment, Timeline"}
          {role==="mgr"&&"👥 Team, Sprint, Resources"}
          {role==="dev"&&"⚙️ Tech Debt, Architecture"}
        </div>
      )}
      {loading&&(<div style={{display:"flex",alignItems:"center",gap:10,fontSize:12,color:C.txt2}}><Spin/> Analyzing 3 layers...</div>)}
      {err&&(<div style={{fontSize:12,color:C.red,background:`${C.red}12`,padding:"10px 12px",borderRadius:8}}>❌ {err}</div>)}
      {structured&&(
        <div style={{display:"flex",flexDirection:"column",gap:10,marginTop:6}}>
          <div style={{background:`${C.indigo}08`,borderLeft:`4px solid ${C.indigo}`,padding:"10px 14px",borderRadius:6}}>
            <div style={{fontSize:11,fontWeight:700,color:C.indigoL,marginBottom:2}}>📊 ACCURACY (Data Used)</div>
            <div style={{fontSize:12,color:C.txt2,display:"flex",flexWrap:"wrap",gap:"4px 16px"}}>
              <span>📁 {structured.data_used?.projects_count||"N/A"}</span>
              <span>📈 {structured.data_used?.avg_health||"N/A"}</span>
              <span>⚠️ {structured.data_used?.critical_risks||"N/A"}</span>
              <span>💰 {structured.data_used?.total_financial||"N/A"}</span>
              <span style={{background:structured.data_used?.quality==="High"?`${C.green}30`:`${C.amber}30`,padding:"0 8px",borderRadius:4,fontWeight:600,fontSize:10}}>
                {structured.data_used?.quality||"Medium"} Quality
              </span>
            </div>
          </div>
          <div style={{background:`${C.green}08`,borderLeft:`4px solid ${C.green}`,padding:"10px 14px",borderRadius:6}}>
            <div style={{fontSize:11,fontWeight:700,color:C.green,marginBottom:2}}>🔒 TRUSTWORTHY (Double-Check)</div>
            <div style={{fontSize:12,color:C.txt2}}>✅ {structured.verification?.cross_check||"Verified"}</div>
            {structured.verification?.warnings?.length>0&&structured.verification.warnings[0]!==null&&(
