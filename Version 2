const askGemini=async(key,prompt)=>{
  const url=`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${key}`;
  const r=await go(url,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({contents:[{parts:[{text:prompt}]}]})});
  if(r&&r.error&&typeof r.error==="object")return{error:true,message:r.error.message||JSON.stringify(r.error)};
  if(r&&r.error===true)return{error:true,message:r.message||"Network/fetch error"};
  const text=r?.candidates?.[0]?.content?.parts?.[0]?.text;
  if(!text)return{error:true,message:"Gemini thi javab na malyo. Raw response: "+JSON.stringify(r).slice(0,300)};
  return{error:false,text};
};
