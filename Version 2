function AnalyticsDashboard({token,companyId,projs,risks}){
  const chartRef = useRef(null);
  const [chartInstance, setChartInstance] = useState(null);
  
  useEffect(()=>{
    if(!projs.length || !risks.length) return;
    
    // Destroy existing chart
    if(chartInstance) chartInstance.destroy();
    
    // Create chart
    const ctx = document.getElementById('analytics-chart');
    if(!ctx) return;
    
    const labels = projs.map(p => p.name);
    const healthData = projs.map(p => p.health_score || 0);
    const riskData = projs.map(p => p.risk_score || 0);
    
    const newChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          { label: 'Health Score', data: healthData, backgroundColor: 'rgba(99,102,241,0.6)', borderColor: '#6366F1', borderWidth: 1 },
          { label: 'Risk Score', data: riskData, backgroundColor: 'rgba(244,63,94,0.6)', borderColor: '#F43F5E', borderWidth: 1 }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: '#A1A1AA' } }
        },
        scales: {
          y: { beginAtZero: true, max: 100, grid: { color: '#27272A' }, ticks: { color: '#A1A1AA' } },
          x: { grid: { color: '#27272A' }, ticks: { color: '#A1A1AA' } }
        }
      }
    });
    setChartInstance(newChart);
    
    return ()=> newChart.destroy();
  }, [projs, risks]);
  
  // Risk distribution pie chart
  useEffect(()=>{
    if(!risks.length) return;
    
    const ctx2 = document.getElementById('risk-pie-chart');
    if(!ctx2) return;
    
    const severityCounts = {
      critical: risks.filter(r => r.severity === 'critical').length,
      high: risks.filter(r => r.severity === 'high').length,
      medium: risks.filter(r => r.severity === 'medium').length,
      low: risks.filter(r => r.severity === 'low').length
    };
    
    new Chart(ctx2, {
      type: 'pie',
      data: {
        labels: ['Critical', 'High', 'Medium', 'Low'],
        datasets: [{
          data: [severityCounts.critical, severityCounts.high, severityCounts.medium, severityCounts.low],
          backgroundColor: ['#F43F5E', '#F59E0B', '#6366F1', '#10B981']
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: '#A1A1AA' } }
        }
      }
    });
  }, [risks]);
  
  const totalHealth = projs.length ? Math.round(projs.reduce((a,p) => a + (p.health_score||0), 0) / projs.length) : 0;
  const totalRisks = risks.length;
  const criticalRisks = risks.filter(r => r.severity === 'critical').length;
  
  return<div className="fu">
