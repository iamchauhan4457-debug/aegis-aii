          <div style={{background:`${C.cyan}08`,borderLeft:`4px solid ${C.cyan}`,padding:"10px 14px",borderRadius:6}}>
            <div style={{fontSize:11,fontWeight:700,color:C.cyan,marginBottom:2}}>🧠 EXPLAINABLE (How & Why)</div>
