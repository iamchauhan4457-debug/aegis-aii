function PDFReports({projs,risks,companyName}){
  const generatePDF = (type) => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    
    doc.setFontSize(18);
    doc.text(`Aegis AI - ${type} Report`, 14, 22);
    doc.setFontSize(10);
    doc.text(`Company: ${companyName || 'N/A'}`, 14, 30);
    doc.text(`Generated: ${new Date().toLocaleString()}`, 14, 36);
    
    if(type === 'Project Summary'){
      doc.autoTable({
        head: [['Name', 'Team', 'Health', 'Risk', 'Status']],
        body: projs.map(p => [p.name, p.team||'-', `${p.health_score||0}%`, `${p.risk_score||0}%`, p.status||'active']),
        startY: 42,
        styles: { fontSize: 8, textColor: '#333' },
        headStyles: { fillColor: '#6366F1', textColor: '#fff' }
      });
    } else if(type === 'Risk Report'){
      doc.autoTable({
        head: [['Description', 'Severity', 'Impact', 'Owner']],
        body: risks.map(r => [r.description, r.severity||'medium', r.financial_impact||'-', r.owner_name||'-']),
        startY: 42,
        styles: { fontSize: 8, textColor: '#333' },
        headStyles: { fillColor: '#6366F1', textColor: '#fff' }
      });
    } else {
      // Weekly Summary
      const totalRisks = risks.length;
      const critical = risks.filter(r=>r.severity==='critical').length;
      doc.text(`Total Projects: ${projs.length}`, 14, 42);
      doc.text(`Total Risks: ${totalRisks}`, 14, 48);
      doc.text(`Critical Risks: ${critical}`, 14, 54);
      doc.text(`Overall Health: ${projs.length ? Math.round(projs.reduce((a,p)=>a+(p.health_score||0),0)/projs.length) : 0}%`, 14, 60);
    }
    
    doc.save(`aegis-${type}-${Date.now()}.pdf`);
  };
  
  return<div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
    <Btn v="out" onClick={()=>generatePDF('Project Summary')}>📄 Projects PDF</Btn>
    <Btn v="out" onClick={()=>generatePDF('Risk Report')}>📄 Risks PDF</Btn>
    <Btn v="out" onClick={()=>generatePDF('Weekly Summary')}>📄 Weekly PDF</Btn>
  </div>;
}

