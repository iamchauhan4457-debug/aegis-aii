        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:16}}>
          <div onClick={()=>sMode("new")} style={{padding:"9px",borderRadius:9,textAlign:"center",cursor:"pointer",border:`1.5px solid ${mode==="new"?C.indigo:C.border}`,background:mode==="new"?`${C.indigo}12`:"transparent",fontSize:12,fontWeight:600,color:mode==="new"?C.indigoL:C.txt2}}>🏢 New Company</div>
          <div onClick={()=>sMode("join")} style={{padding:"9px",borderRadius:9,textAlign:"center",cursor:"pointer",border:`1.5px solid ${mode==="join"?C.indigo:C.border}`,background:mode==="join"?`${C.indigo}12`:"transparent",fontSize:12,fontWeight:600,color:mode==="join"?C.indigoL:C.txt2}}>🔗 Join Company</div>
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:12}}>
          <Inp lbl="Full Name" ph="Raj Patel" val={form.name} onChange={f("name")}/>
          <Inp lbl="Work Email" ph="raj@company.com" val={form.email} onChange={f("email")} type="email"/>
