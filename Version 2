      <Card><div style={{fontSize:11,color:C.txt2,marginBottom:4}}>Avg Health</div><div style={{fontSize:24,fontWeight:900,color:C.green}}>{totalHealth}%</div></Card>
      <Card><div style={{fontSize:11,color:C.txt2,marginBottom:4}}>Total Risks</div><div style={{fontSize:24,fontWeight:900,color:C.indigo}}>{totalRisks}</div></Card>
      <Card><div style={{fontSize:11,color:C.txt2,marginBottom:4}}>Critical Risks</div><div style={{fontSize:24,fontWeight:900,color:C.red}}>{criticalRisks}</div></Card>
      <Card><div style={{fontSize:11,color:C.txt2,marginBottom:4}}>Projects</div><div style={{fontSize:24,fontWeight:900,color:C.cyan}}>{projs.length}</div></Card>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:12}}>
      <div className="chart-container" style={{height:300}}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12}}>📊 Project Health vs Risk</div>
        <canvas id="analytics-chart" style={{width:'100%',height:'250px'}}></canvas>
      </div>
      <div className="chart-container" style={{height:300}}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12}}>📊 Risk Distribution</div>
        <canvas id="risk-pie-chart" style={{width:'100%',height:'250px'}}></canvas>
      </div>
