function Signup({onLogin}){
  const[mode,sMode]=useState("new");
  const[form,sF]=useState({name:"",email:"",pw:"",role:"mgr",co:"",code:""});const[err,sErr]=useState("");const[loading,sL]=useState(false);const[status,sSt]=useState("");
  const f=k=>e=>sF({...form,[k]:e.target.value});
  const go=async()=>{
    if(!form.name||!form.email||!form.pw){sErr("Badha fields jaroori che");return;}
    if(form.pw.length<6){sErr("Password min 6 characters");return;}
    if(mode==="new"&&!form.co){sErr("Company Name nakho");return;}
    if(mode==="join"&&!form.code){sErr("Invite Code nakho");return;}
    sL(true);sErr("");sSt("Account banavi rahyu che...");
    try{
      const d=await api.up(form.email,form.pw,form.name,form.role);
      if(d.user||d.access_token){
        sSt("Login kari rahyu che...");
        const d2=await api.in(form.email,form.pw);
        if(d2.access_token){
          const tok=d2.access_token;const uid=d2.user.id;
          if(mode==="new"){
            sSt("Company setup kari rahyu che...");
            const comp=await api.createCompany(tok,uid,form.co);
            const c=Array.isArray(comp)?comp[0]:comp;
            if(!c||!c.id){sL(false);sSt("");sErr("Company banavva ma error aavyu — pharthi try karo");return;}
            await api.upsertProf(tok,uid,{full_name:form.name,role:form.role,company_id:c.id,company_name:c.name});
          }else{
            sSt("Company sodhi rahya che...");
            const c=await api.findCompanyByCode(tok,form.code.trim());
            if(!c){sL(false);sSt("");sErr("Invite Code khoto che — sachu code check karo");return;}
            await api.upsertProf(tok,uid,{full_name:form.name,role:form.role,company_id:c.id,company_name:c.name});
          }
          sL(false);sSt("");onLogin(d2);
        }else{sL(false);sSt("");sErr("Account banyu! Hav login karo.");}
      }
      else{sL(false);sSt("");const em=d.msg||d.error_description||d.message||d.error||JSON.stringify(d);if(em.includes("already")||em.includes("registered"))sErr("Aa email thi account che — Login karo!");else sErr(em);}
    }catch(e){sL(false);sSt("");sErr("Network issue — internet check karo");}
  };
  return<div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:`radial-gradient(ellipse at 40% 0%, ${C.cyan}10 0%, ${C.bg} 60%)`,padding:20}}>
