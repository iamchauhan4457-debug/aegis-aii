// ACTIVITY PAGE
// ============================================================
function ActivityPage({token,companyId}){
  return<div>
    <Card sx={{marginBottom:14}}>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8}}>📋 Activity Feed</div>
      <ActivityFeed token={token} companyId={companyId}/>
    </Card>
