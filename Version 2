  useEffect(()=>{
    if(!companyId){sL(false);return;}
    Promise.all([api.projs(token,companyId),api.risks(token,companyId)]).then(([p,r])=>{
      sP(Array.isArray(p)?p:[]);
      sR(Array.isArray(r)?r:[]);
      sL(false);
    });
  },[token,companyId]);
  if(loading)return<div style={{display:"flex",justifyContent:"center",padding:40}}><Spin/></div>;
  const total=projs.length;
  const healthy=projs.filter(p=>p.status==="healthy").length;
  const atRisk=projs.filter(p=>p.status==="at-risk").length;
  const critical=risks.filter(r=>r.severity==="critical").length;
  const totalRisks=risks.length;
  return<div style={{maxWidth:600}}>
    <Card><div style={{fontSize:14,fontWeight:700,marginBottom:12}}>📊 Weekly Summary</div>
      <div style={{fontSize:13,color:C.txt2,lineHeight:1.6}}>
        <div style={{marginBottom:12}}>📁 <strong>Projects:</strong> {total} active, {healthy} healthy, {atRisk} at risk</div>
        <div style={{marginBottom:12}}>⚠️ <strong>Risks:</strong> {totalRisks} identified, {critical} critical</div>
        <div style={{marginBottom:12}}>👥 <strong>Team:</strong> {prof?.full_name||"You"}'s team is working on {total} projects</div>
        <div>💾 Data as of {new Date().toLocaleDateString()}</div>
      </div>
      <Btn v="out" full sx={{marginTop:16}} onClick={()=>{
        const csv="Project,Status,Health\n"+projs.map(p=>`${p.name},${p.status},${p.health_score}`).join("\n");
        const blob=new Blob([csv],{type:"text/csv"});const url=window.URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download="weekly-summary.csv";a.click();
      }}>📥 Export CSV</Btn>
    </Card>
  </div>;
}

// ============================================================
// SETTINGS (Updated with 2FA, Backup, SSO)
// ============================================================
function Settings({token,uid,prof,onUpdate,onNav,companyId}){
  const[form,sF]=useState({full_name:prof?.full_name||"",company_name:prof?.company_name||""});
  const[saving,sSv]=useState(false);const[toast,sT]=useState(null);
  const[gk,sGk]=useState(gemKey.get());
  const[twoFA,sTwoFA]=useState(false);
  const roleLbl={ceo:"CEO / Founder",mgr:"Engineering Manager",dev:"Developer"}[prof?.role]||"Engineering Manager";
  const f=k=>e=>sF({...form,[k]:e.target.value});
  const save=async()=>{sSv(true);await api.saveProf(token,uid,form);gemKey.set(gk);sSv(false);onUpdate(form);sT({msg:"Saved! ✅",type:"success"});setTimeout(()=>sT(null),3000);};
  const exportCSV=async()=>{
    if(!companyId){sT({msg:"No company data to export","error":true});return;}
    const [projs,risks]=await Promise.all([api.projs(token,companyId),api.risks(token,companyId)]);
    let csv="Project Data\n";
    csv+="Name,Team,Sprint,Health,Risk,Status\n";
    projs.forEach(p=>csv+=`${p.name},${p.team||""},${p.sprint||""},${p.health_score},${p.risk_score},${p.status}\n`);
    csv+="\nRisks\n";
    csv+="Description,Severity,Impact,Owner\n";
    risks.forEach(r=>csv+=`${r.description},${r.severity},${r.financial_impact||""},${r.owner_name||""}\n`);
    const blob=new Blob([csv],{type:"text/csv"});const url=window.URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download="aegis-full-export.csv";a.click();
    sT({msg:"CSV exported ✅",type:"success"});setTimeout(()=>sT(null),3000);
  };
  
  return<div className="fu" style={{maxWidth:460}}>
    {toast&&<Toast msg={toast.msg} type={toast.type}/>}
    <Card>
      <div style={{display:"flex",gap:12,alignItems:"center",marginBottom:16}}><Av n={form.full_name} s={50}/><div><div style={{fontSize:14,fontWeight:700}}>{form.full_name||"Your Name"}</div><div style={{fontSize:12,color:C.txt3}}>Aegis AI</div></div></div>
      <Hr m={14}/>
      <div style={{display:"flex",flexDirection:"column",gap:12}}>
        <Inp lbl="Full Name" ph="Raj Patel" val={form.full_name} onChange={f("full_name")}/>
        <Inp lbl="Company Name" ph="Acme Corp" val={form.company_name} onChange={f("company_name")}/>
        <div>
          <div style={{fontSize:12,fontWeight:600,color:C.txt2,marginBottom:6}}>Role</div>
          <div style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:C.surf,border:`1px solid ${C.border}`,borderRadius:9}}>
            <Chip l={roleLbl}/>
            <span style={{fontSize:11,color:C.txt3}}>🔒 Signup time e fix thayel, badli na shakay</span>
          </div>
        </div>
        <Btn v="grad" onClick={save} dis={saving}>{saving?<Spin/>:"✓ Save Changes"}</Btn>
      </div>
    </Card>
    
    <Card sx={{marginTop:14}}>
      <div style={{fontSize:14,fontWeight:700,marginBottom:4}}>✨ AI Insights (Gemini)</div>
      <div style={{fontSize:12,color:C.txt2,marginBottom:14}}>Dashboard par AI-based project analysis mate free Gemini API key nakho. Key <span style={{color:C.indigoL}}>aistudio.google.com/apikey</span> parthi malshe — badhu tamara browser ma j save thay che.</div>
      <div style={{display:"flex",flexDirection:"column",gap:12}}>
        <Inp lbl="Gemini API Key" ph="AIzaSy..." val={gk} onChange={e=>sGk(e.target.value)} type="password"/>
        <Btn v="out" onClick={save} dis={saving}>{saving?<Spin/>:"Save API Key"}</Btn>
      </div>
    </Card>
    
    {/* 2FA */}
    <Card sx={{marginTop:14}}><TwoFactorAuth onEnable={sTwoFA}/></Card>
    
    {/* Data Backup */}
    <Card sx={{marginTop:14}}><DataBackup token={token} companyId={companyId}/></Card>
    
    <Card sx={{marginTop:14}}>
      <div style={{fontSize:14,fontWeight:700,marginBottom:12}}>📊 Data & Legal</div>
      <div style={{display:"flex",flexDirection:"column",gap:8}}>
        <Btn v="ghost" full onClick={exportCSV}>📥 Export as CSV (Full Data)</Btn>
        <Btn v="ghost" full onClick={()=>onNav("privacy")}>📋 Privacy Policy</Btn>
        <Btn v="ghost" full onClick={()=>onNav("terms")}>⚖️ Terms of Service</Btn>
      </div>
    </Card>
  </div>;
}

// ============================================================
// NAVIGATION TITLES
// ============================================================
const TT={dash:"Dashboard",analytics:"Analytics",proj:"Projects",risks:"Risk Center",team:"Team",chat:"Chat",audit:"Activity Log",summary:"Weekly Summary",privacy:"Privacy Policy",terms:"Terms of Service",cfg:"Settings",project_detail:"Project Detail"};

// ============================================================
// PRIVACY & TERMS
// ============================================================
function PrivacyTerms({page,onBack}){
  const content={privacy:{title:"Privacy Policy",text:"Aegis AI respects your privacy. Your company data is isolated and encrypted. We do not share your data with third parties without consent."},terms:{title:"Terms of Service",text:"By using Aegis AI, you agree to our terms. Your usage is governed by the pricing plan you select. Billing is monthly and can be cancelled anytime."}};
  const p=content[page]||content.privacy;
  return<div style={{maxWidth:700,margin:"0 auto"}}><div onClick={onBack} style={{color:C.txt2,cursor:"pointer",marginBottom:20}}>← Back</div><h1 style={{fontSize:24,fontWeight:900,marginBottom:20}}>{p.title}</h1><div style={{lineHeight:1.8,color:C.txt2,fontSize:14}}>{p.text}</div></div>;
}

// ============================================================
// AUDIT LOG
// ============================================================
function AuditLog({token,companyId}){
  const[logs,setLogs]=useState([]);const[loading,sL]=useState(true);
  useEffect(()=>{
    if(!companyId){sL(false);return;}
    api.getAuditLog(token,companyId).then(l=>{setLogs(l);sL(false);});
  },[companyId,token]);
  if(loading)return<div style={{textAlign:"center",padding:40}}><Spin/></div>;
  if(!companyId)return<Card><div style={{textAlign:"center",padding:20,color:C.txt2}}>No company assigned.</div></Card>;
  return<div style={{maxWidth:700}}><Card><div style={{fontSize:14,fontWeight:700,marginBottom:12}}>Activity Log</div>{logs.length===0?<div style={{color:C.txt3}}>No activity yet</div>:logs.map(l=><div key={l.id} style={{padding:10,background:C.surf,borderRadius:8,marginBottom:8,fontSize:12}}><div style={{fontWeight:600}}>{l.action}</div><div style={{color:C.txt3,marginTop:4}}>{new Date(l.created_at).toLocaleString()}</div></div>)}</Card></div>;
}

// ============================================================
// RESET PASSWORD
// ============================================================
function ResetPw({token,onDone}){
  const[pw,sPw]=useState("");const[pw2,sPw2]=useState("");const[err,sErr]=useState("");const[loading,sL]=useState(false);const[done,sDone]=useState(false);
  const submit=async()=>{
    if(!pw||pw.length<6){sErr("Password min 6 characters joie");return;}
    if(pw!==pw2){sErr("Password match nathi thato");return;}
    sL(true);sErr("");
    const d=await go(`${SB}/auth/v1/user`,{method:"PUT",headers:{...H(token)},body:JSON.stringify({password:pw})});
    sL(false);
    if(d&&d.id){sDone(true);setTimeout(()=>onDone(),2000);}
    else sErr(d.msg||d.message||d.error||"Password update na thayo — link expire thai gayu hoy shake");
  };
  return<div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:C.bg,padding:20}}>
    <div style={{width:"100%",maxWidth:360}}>
      <div style={{textAlign:"center",marginBottom:22}}><Logo s={40}/><h2 style={{fontSize:20,fontWeight:800,marginTop:10,marginBottom:4}}>Set new password</h2><p style={{color:C.txt2,fontSize:13}}>Enter a new password for your account</p></div>
      <Card sx={{padding:22}}>
        {done?<div style={{textAlign:"center",padding:6}}>
          <div style={{fontSize:32,marginBottom:10}}>✅</div>
          <div style={{fontSize:14,fontWeight:700,marginBottom:6}}>Password update thayo!</div>
          <div style={{fontSize:13,color:C.txt2}}>Login page par jai rahya cho...</div>
        </div>:<div style={{display:"flex",flexDirection:"column",gap:12}}>
          <Inp lbl="New Password" ph="Min 6 characters" val={pw} onChange={e=>sPw(e.target.value)} type="password"/>
          <Inp lbl="Confirm Password" ph="Pharthi nakho" val={pw2} onChange={e=>sPw2(e.target.value)} type="password"/>
          {err&&<div style={{fontSize:12,color:C.red,background:`${C.red}12`,padding:"8px 12px",borderRadius:7}}>{err}</div>}
          <Btn v="grad" full sz="lg" onClick={submit} dis={loading}>{loading?<Spin/>:"Update Password"}</Btn>
        </div>}
      </Card>
    </div>
  </div>;
}

// ============================================================
// CHAT PAGE (Project-specific chat)
